{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist-cli",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noEmit": false,
    "resolveJsonModule": true
  },
  "include": [
    "src/cli.ts",
    "src/pdf-node.ts",
    "src/services/llm.ts",
    "src/services/config.ts",
    "src/utils/prompt.ts"
  ]
}
