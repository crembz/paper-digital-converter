{
  "name": "paper-digital-converter",
  "version": "0.5.1",
  "description": "Convert paper notes to digital markdown using LLM vision",
  "main": "dist-electron/main.js",
  "bin": {
    "paper-converter": "./bin/paper-converter"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder --config electron-builder.yml",
    "build-cli": "tsc --project tsconfig.cli.json",
    "preview": "vite preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.18.0",
    "@napi-rs/canvas": "^1.0.2",
    "commander": "^15.0.0",
    "dotenv": "^16.3.1",
    "openai": "^4.28.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "react-markdown": "^9.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  },
  "build": {
    "win": {
      "sign": null,
      "signingHashAlgorithms": [],
      "certificateSubjectName": null,
      "signAndEditExecutable": false
    },
    "extraMetadata": {}
  },
  "allowScripts": {
    "electron@28.3.3": true,
    "esbuild@0.21.5": true
  }
}
